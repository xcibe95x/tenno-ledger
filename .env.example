# All optional — without these the app runs with browser-local saves only,
# and the corresponding sync UI stays hidden.

# Google Drive sync (recommended): create an OAuth "Web application" client at
# console.cloud.google.com (APIs & Services -> Credentials), enable the Google
# Drive API, and add your site origin (e.g. http://localhost:5173) to the
# authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=YOUR-CLIENT-ID.apps.googleusercontent.com
